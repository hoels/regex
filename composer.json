{
    "name": "hoels/regex",
    "version": "1.1.0",
    "description": "A wrapper for regular expressions.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Regex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Regex\\Tests\\": "tests"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.4",
        "squizlabs/php_codesniffer": "^3.6"
    }
}
